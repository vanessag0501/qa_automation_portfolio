  "item": [
    {
      "name": "Get All Posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Returns 100 posts\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.length).to.eql(100);\r",
              "});\r",
              "\r",
              "pm.test(\"First post has required fields\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json[0]).to.have.property(\"id\");\r",
              "    pm.expect(json[0]).to.have.property(\"title\");\r",
              "    pm.expect(json[0]).to.have.property(\"body\");\r",
              "    pm.expect(json[0]).to.have.property(\"userId\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is under 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts"
          ]
        }
      },
      "response": []
    },
